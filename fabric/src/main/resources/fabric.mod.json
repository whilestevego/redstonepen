{
  "schemaVersion": 1,
  "id": "redstonepen",
  "version": "${version}",
  "name": "Redstone Pen",
  "description": "Adds a pen to draw detailed Redstone tracks, as well as Redstone relays, and the Redstone Logic Controller.",
  "authors": [ "wilechaote" ],
  "contact": {
    "homepage": "https://github.com/stfwi/redstonepen",
    "sources": "https://github.com/stfwi/redstonepen",
    "issues": "https://github.com/stfwi/redstonepen/issues"
  },
  "license": "MIT",
  "icon": "assets/redstonepen/logo.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "wile.redstonepen.fabric.ModRedstonePen"
    ],
    "client": [
      "wile.redstonepen.fabric.ModRedstonePenClient"
    ],
    "fabric-gametest": [
      "wile.redstonepen.gametest.AuxiliariesGameTests",
      "wile.redstonepen.gametest.BasicLeverButtonGameTests",
      "wile.redstonepen.gametest.ControlBoxGameTests",
      "wile.redstonepen.gametest.DemoGameTests",
      "wile.redstonepen.gametest.InventoriesGameTests",
      "wile.redstonepen.gametest.PenItemGameTests",
      "wile.redstonepen.gametest.RecipeGameTests",
      "wile.redstonepen.gametest.RelayGameTests",
      "wile.redstonepen.gametest.RemoteItemGameTests",
      "wile.redstonepen.gametest.TrackGameTests"
    ]
  },
  "mixins": [
    "redstonepen.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "fabric-api": "*",
    "minecraft": ">=1.21 <1.22",
    "java": ">=21"
  }
}
